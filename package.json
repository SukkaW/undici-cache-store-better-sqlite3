{
  "name": "undici-cache-store-better-sqlite3",
  "version": "1.0.0",
  "description": "A undici cache store powered by `better-sqlite3` instead of `node:sqlite`",
  "repository": {
    "url": "https://github.com/SukkaW/undici-cache-store-better-sqlite3"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/es/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.mts",
        "default": "./dist/es/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "lint": "eslint --format=sukka .",
    "build": "bunchee --minify --runtime nodejs",
    "prerelease": "pnpm run lint && pnpm run build",
    "release": "bumpp -r --all --commit \"release: %s\" --tag \"%s\""
  },
  "keywords": [
    "undici",
    "cache",
    "cache store",
    "sqlite",
    "http cache"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "foxts": "^5.3.0"
  },
  "devDependencies": {
    "@eslint-sukka/node": "^8.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "bumpp": "^10.4.1",
    "bunchee": "^6.9.4",
    "eslint": "^10.0.3",
    "eslint-config-sukka": "^8.8.0",
    "eslint-formatter-sukka": "^8.8.0",
    "typescript": "^5.9.3",
    "undici": "^7.24.3"
  },
  "peerDependencies": {
    "undici": ">=7.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
