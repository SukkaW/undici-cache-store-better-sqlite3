{
  "name": "undici-cache-store-better-sqlite3",
  "version": "1.0.0",
  "description": "A undici cache store powered by `better-sqlite3` instead of `node:sqlite`",
  "repository": {
    "url": "https://github.com/SukkaW/undici-cache-store-better-sqlite3"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/es/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/es/index.d.mts",
        "default": "./dist/es/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "lint": "eslint --format=sukka .",
    "build": "bunchee --minify --runtime nodejs",
    "prerelease": "pnpm run lint && pnpm run build",
    "release": "bumpp -r --all --commit \"release: %s\" --tag \"%s\""
  },
  "keywords": [
    "undici",
    "cache",
    "cache store",
    "sqlite",
    "http cache"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "foxts": "^4.0.0"
  },
  "devDependencies": {
    "@eslint-sukka/node": "^7.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.18.8",
    "bumpp": "^10.2.3",
    "bunchee": "^6.6.0",
    "eslint": "^9.36.0",
    "eslint-config-sukka": "^7.2.1",
    "eslint-formatter-sukka": "^7.2.1",
    "typescript": "^5.9.3",
    "undici": "^7.16.0"
  },
  "peerDependencies": {
    "undici": ">=7.0.0"
  },
  "packageManager": "pnpm@10.18.0"
}
